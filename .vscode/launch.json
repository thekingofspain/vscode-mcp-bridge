{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "E2E: Launch Extension (Keep Open)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--disable-extensions",
        "--disable-gpu"
      ],
      "outFiles": [
        "${workspaceFolder}/out/extension.js"
      ],
      "preLaunchTask": "npm: build"
    },
    {
      "name": "E2E: Run Tests",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionTestsPath=${workspaceFolder}/out/tests/e2e/extension.e2e.test.js",
        "--disable-extensions",
        "--disable-gpu"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ]
    }
  ]
}