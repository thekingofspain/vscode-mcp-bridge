{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": [
      "ES2022"
    ],
    "outDir": "out",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "baseUrl": "src",
    "paths": {
      "@commands/*": [
        "commands/*"
      ],
      "@config/*": [
        "config/*"
      ],
      "@extension/*": [
        "extension/*"
      ],
      "@mcp/*": [
        "mcp/*"
      ],
      "@services/*": [
        "services/*"
      ],
      "@type-defs/*": [
        "types/*"
      ],
      "@utils/*": [
        "utils/*"
      ],
      "@vscode-api/*": [
        "vscode-api/*"
      ],
      "@generated/*": [
        "../.generated/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    ".generated/**/*",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "out",
    "scripts",
    "types"
  ]
}